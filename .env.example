# Copy this file to .env and fill in values before running the agent.
# The agent never reads .env automatically — export variables in your shell
# or use `dotenv` / a process manager to inject them.

# ── LLM Sidecar ────────────────────────────────────────────────────────────────
# Required only when sidecar.enabled = true in config/agent.toml.
# Anthropic API key (default provider).
LLM_API_KEY=sk-ant-...

# Alternative: OpenAI-compatible key (set llm_provider = "openai" in config).
# OPENAI_API_KEY=sk-...

# ── Solana RPC ─────────────────────────────────────────────────────────────────
# Override RPC endpoints at runtime instead of editing the TOML.
# L1_ENDPOINT=https://api.mainnet-beta.solana.com
# ER_ENDPOINT=wss://er.magicblock.app/table

# ── Agent keypair ──────────────────────────────────────────────────────────────
# Path to the agent's Solana keypair JSON (array of 64 bytes).
# Default: ./keys/agent-alpha.json (auto-generated on first run if missing).
# AGENT_KEYPAIR_PATH=./keys/agent-alpha.json

# ── Observability ──────────────────────────────────────────────────────────────
# LOG_LEVEL=info    # debug | info | warn | error
